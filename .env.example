# ====== AIfa Works Creativity — пример переменных окружения ======
# Реальные значения держим в .env (он в .gitignore) или в Secret Manager на проде.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:PUT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=generate_a_long_random_string
TELEGRAM_BOT_USERNAME=AIfaCreativityBot

# --- Database (Neon Postgres + pgvector) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Payments: NOWPayments ---
NOWPAYMENTS_API_KEY=put_api_key_here
NOWPAYMENTS_IPN_SECRET=put_ipn_secret_here

# --- AI: Gemini / Vertex (Phase 3) ---
GEMINI_API_KEY=put_grant_project_key_here
GCP_PROJECT_ID=project-72844ae8-a294-4048-980

# --- Server ---
PORT=8080
PUBLIC_BASE_URL=https://your-cloud-run-url.run.app
NODE_ENV=development

# --- Referral engine ---
REF_TIER1_PCT=30
REF_TIER2_PCT=40
REF_TIER3_PCT=50
REF_PRESTIGE_FLOOR_PCT=45
